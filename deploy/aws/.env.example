# Copy to the repo root as `.env` on the instance and set REAL values before the
# gateway is reachable from the internet. docker-compose reads `.env` automatically.
# NEVER commit the filled-in .env (it is gitignored).

# JWT signing secret — MUST be long/random in production. Generate one with e.g.
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_48

# The single demo credential the token endpoint accepts.
AUTH_USERNAME=admin
AUTH_PASSWORD=CHANGE_ME_strong_password

# Grafana admin login. Grafana is NOT exposed publicly (reach it via SSH tunnel:
#   ssh -L 3000:localhost:3000 <user>@<ec2-host>  then open http://localhost:3000)
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_strong_password

# NOTE: PostgreSQL runs only on the internal compose network (never published to
# the host or the internet), so its default credentials in docker-compose.yml are
# acceptable for this demo. Move them here + to a managed store if you ever expose it.
